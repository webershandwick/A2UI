                "h1",
                "h2",
                "h3",
                "h4",
                "h5",
                "caption",
                "body"
              ],
              "default": "body"
            }
          },
          "required": [
            "component",
            "text"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Image": {
