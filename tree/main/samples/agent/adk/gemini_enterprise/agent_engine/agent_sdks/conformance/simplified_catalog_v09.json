{
  "catalogId": "test_catalog",
  "components": {
    "Container": {
      "type": "object",
      "allOf": [
        { "$ref": "simplified_common_types_v09.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" }
      ],
      "properties": {
        "component": { "const": "Container" },
        "children": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [ "component", "children" ]
    },
    "Card": {
      "type": "object",
      "allOf": [
        { "$ref": "simplified_common_types_v09.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" }
      ],
      "properties": {
        "component": { "const": "Card" },
        "child": { "$ref": "simplified_common_types_v09.json#/$defs/ComponentId" }
      },
      "required": [ "component", "child" ]
    },
    "Text": {
      "type": "object",
      "allOf": [
        { "$ref": "simplified_common_types_v09.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" }
      ],
      "properties": {
        "component": { "const": "Text" },
        "text": { "$ref": "simplified_common_types_v09.json#/$defs/DynamicString" }
      },
      "required": [ "component", "text" ]
    },
    "Column": {
      "type": "object",
      "allOf": [
        { "$ref": "simplified_common_types_v09.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" }
      ],
      "properties": {
        "component": { "const": "Column" },
        "children": { "$ref": "simplified_common_types_v09.json#/$defs/ChildList" }
      },
      "required": [ "component", "children" ]
    },
    "AudioPlayer": {
      "type": "object",
      "allOf": [
        { "$ref": "simplified_common_types_v09.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "AudioPlayer" },
            "url": { "$ref": "simplified_common_types_v09.json#/$defs/DynamicString" },
            "description": { "$ref": "simplified_common_types_v09.json#/$defs/DynamicString" }
          },
          "required": [ "component", "url" ]
        }
      ]
    },
    "List": {
      "type": "object",
      "allOf": [
        { "$ref": "simplified_common_types_v09.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "List" },
            "children": { "$ref": "simplified_common_types_v09.json#/$defs/ChildList" },
            "direction": {
              "type": "string",
              "enum": [ "vertical", "horizontal" ]
            }
          },
          "required": [ "component", "children" ]
        }
      ]
    },
    "Row": {
      "type": "object",
      "allOf": [
        { "$ref": "simplified_common_types_v09.json#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "Row" },
            "children": { "$ref": "simplified_common_types_v09.json#/$defs/ChildList" }
          },
          "required": [ "component", "children" ]
        }
      ]
    }
  },
  "$defs": {
    "CatalogComponentCommon": {
      "type": "object",
      "properties": { "weight": { "type": "number" } }
    },
    "anyComponent": {
      "oneOf": [
        { "$ref": "#/components/Container" },
        { "$ref": "#/components/Card" },
        { "$ref": "#/components/Text" },
        { "$ref": "#/components/Column" },
        { "$ref": "#/components/AudioPlayer" },
        { "$ref": "#/components/List" },
        { "$ref": "#/components/Row" }
      ],
      "discriminator": { "propertyName": "component" }
    }
  }
}
